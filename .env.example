# =========================================================================
#                    URIMAI VAZHI - ENVIRONMENT VARIABLES
# =========================================================================
# This file serves as a guide for local and container environments.
# To configure the app, copy this file to '.env' and fill out the secrets.
#
# NOTE: In Google AI Studio preview, these variables are managed automatically
# or entered via the "Settings / Secrets" side panel.
# =========================================================================

# 1. GOOGLE GEMINI AI CONFIGURATION (AI SERVICE SEPARATED LAYER)
# Enter your official Google Gemini API Key.
# Get yours at: https://aistudio.google.com/
# Critical: Keep this server-side only. Do NOT prefix with "VITE_" to keep it secure.
GEMINI_API_KEY=

# 2. RUNTIME AND SELF-REFERENTIAL PATHS
# The root hosting URL for the full-stack system.
# Google AI Studio will automatically inject this value inside production containers.
# APP_URL="http://localhost:3000"

# 3. FIREBASE SECURE BACKEND INTEGRATION
# In AI Studio, Firebase Auth & Firestore rules are provisioned on demand.
# Values are loaded dynamically from `/firebase-applet-config.json` at runtime.
# For manual custom deployments, declare public key configurations here:
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=

