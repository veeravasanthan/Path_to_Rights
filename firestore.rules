rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }

    // Entity validator: User Profile
    function isValidUser(data) {
      return data.userId is string 
        && data.userId == request.auth.uid 
        && data.email is string 
        && data.email.size() <= 256;
    }

    // Entity validator: Summary
    function isValidSummary(data, userId) {
      return data.id is string
        && data.userId == request.auth.uid
        && data.userId == userId
        && data.documentType is string
        && data.documentType.size() <= 256;
    }

    // Collection matches
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) 
        && request.resource.data.userId == resource.data.userId;
      allow delete: if false; // Profiles are permanent

      match /summaries/{summaryId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(summaryId) && isValidSummary(request.resource.data, userId);
        allow update: if isOwner(userId) && isValidId(summaryId) && isValidSummary(request.resource.data, userId)
          && request.resource.data.id == resource.data.id
          && request.resource.data.userId == resource.data.userId;
        allow delete: if isOwner(userId);
      }
    }
  }
}
